# Exported sessions / transcripts - never commit conversation data
*.jsonl
*.zip
*.tar.gz
manifest.json

# ...but DO track the hand-made test fixtures (tiny, synthetic, no real user data).
# These exceptions must come AFTER the ignore rules above to take effect.
!tests/fixtures/
!tests/fixtures/**

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

# Node (for the future cross-OS CLI)
node_modules/
npm-debug.log*

# Local-only project notes (private, never pushed)
ROADMAP.md
docs/superpowers/
